rules_version = '2';

// Datenmodell: teams/{teamId}/{meta,members,invites,players,events,opponents}
// Siehe README/FIREBASE_SETUP.md fuer den Hintergrund. Kernidee:
// - "members/{uid}" verknuepft eine angemeldete Firebase-Auth-Identitaet mit einer
//   Rolle ("trainer" oder "player") und - fuer Spieler - der eigenen playerId.
// - Ein Trainer darf alles lesen/schreiben. Ein Spieler darf nur sein eigenes
//   Spielerprofil, seinen eigenen Foerderplan und seine eigenen Bewertungen lesen -
//   nie die Daten anderer Spieler.
service cloud.firestore {
  match /databases/{database}/documents {
    match /teams/{teamId} {

      function isSignedIn() {
        return request.auth != null;
      }

      function memberExists() {
        return exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      }

      function memberDoc() {
        return get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      }

      // Spieler-Zugaenge koennen ein Ablaufdatum ("expiresAt", Timestamp) haben - fehlt
      // das Feld oder ist es null, ist der Zugang unbefristet. Trainer-Dokumente (manuell
      // in der Firebase-Konsole angelegt, siehe FIREBASE_SETUP.md) haben das Feld ueberhaupt
      // nicht gesetzt. Direkter Feldzugriff (".data.expiresAt") wuerde in diesem Fall die
      // gesamte Regelauswertung mit einem Fehler abbrechen (Firestore behandelt den Zugriff
      // auf ein nicht vorhandenes Map-Feld nicht als "null", sondern als Auswertungsfehler -
      // das war vermutlich die Ursache des fruehren, nie ganz geklaerten isTrainer()-Bugs).
      // ".get(feld, default)" ist der dafuer vorgesehene, sichere Zugriffsweg.
      function isExpired() {
        return memberDoc().data.get('expiresAt', null) != null && memberDoc().data.get('expiresAt', null) < request.time;
      }

      function isTeamMember() {
        return isSignedIn() && memberExists() && !isExpired();
      }

      function isTrainer() {
        return isTeamMember() && memberDoc().data.role == "trainer";
      }

      function isPlayerFor(playerId) {
        return isTeamMember() && memberDoc().data.role == "player" && memberDoc().data.playerId == playerId;
      }

      match /members/{uid} {
        // Trainer duerfen die ganze Liste sehen (Zugaenge verwalten); diese Regel
        // haengt nicht von resource-Daten ab und ist daher fuer Listenabfragen sicher.
        allow read: if isTrainer() || (isSignedIn() && request.auth.uid == uid);
        // Trainer-Mitgliedschaften ("role": "trainer") werden absichtlich NICHT ueber
        // die App erstellt, sondern ausschliesslich manuell in der Firebase-Konsole
        // (Authentication: Nutzer anlegen: Firestore: passendes members/{uid}-Dokument
        // anlegen) - siehe FIREBASE_SETUP.md. Die Konsole ist von diesen Regeln ohnehin
        // nicht betroffen, es braucht dafuer also keine eigene "allow create"-Regel.
        // Ueber die App selbst kann sich ausschliesslich ein Spieler ueber einen gueltigen
        // Einladungscode eintragen. Der Code ist bewusst mehrfach nutzbar (wie ein
        // Passwort, kein Einmal-Link) - jedes Geraet, das den Code eingibt, bekommt eine
        // eigene anonyme Identitaet und damit sein eigenes members-Dokument.
        // Die Diagnose (auch "if true" scheiterte beim allerersten Versuch nach einem
        // Deploy, klappte aber nach einem Neuladen) zeigt: es lag nie an der Regel-Logik,
        // sondern an der kurzen Verzoegerung, bis ein frisch deployter Regelsatz global
        // greift. Deshalb wieder die vollstaendige, sichere Pruefung inkl. Einladungscode-
        // und Ablaufdatum-Abgleich.
        allow create: if isSignedIn() && request.auth.uid == uid
          && request.resource.data.role == "player"
          && request.resource.data.playerId is string
          && request.resource.data.claimedInviteCode is string
          && get(/databases/$(database)/documents/teams/$(teamId)/invites/$(request.resource.data.claimedInviteCode)).data.playerId == request.resource.data.playerId
          && request.resource.data.expiresAt == get(/databases/$(database)/documents/teams/$(teamId)/invites/$(request.resource.data.claimedInviteCode)).data.expiresAt
          && (
            get(/databases/$(database)/documents/teams/$(teamId)/invites/$(request.resource.data.claimedInviteCode)).data.expiresAt == null
            || get(/databases/$(database)/documents/teams/$(teamId)/invites/$(request.resource.data.claimedInviteCode)).data.expiresAt > request.time
          );
        // Kein Update: eine bestehende Mitgliedschaft wird nicht bearbeitet, sondern
        // vom Trainer geloescht (Zugang sperren) und bei Bedarf neu eingeladen.
        allow update: if false;
        allow delete: if isTrainer();
      }

      match /invites/{code} {
        // Ein frisch (anonym) angemeldeter Spieler ist zu diesem Zeitpunkt noch kein
        // Teammitglied - er muss den EINEN Code, den er kennt, trotzdem lesen duerfen,
        // um sich ueberhaupt registrieren zu koennen. "get" (gezielter Abruf eines
        // bekannten Codes) wird deshalb fuer jeden Angemeldeten erlaubt; "list" (alle
        // Codes auflisten) bleibt bewusst auf Trainer beschraenkt.
        allow get: if isTrainer() || isSignedIn();
        allow list: if isTrainer();
        // War zwischenzeitlich eine abgeflachte Sonderpruefung (isTrainer() schlug hier
        // unerklaert fehl) - die Ursache ist inzwischen gefunden und behoben: isExpired()
        // griff direkt auf ein bei Trainer-Konten fehlendes "expiresAt"-Feld zu, was die
        // gesamte Regelauswertung mit einem Fehler abbrechen liess statt "false" zu liefern.
        // Jetzt wieder die normale, konsistente Pruefung.
        allow create: if isTrainer();
        // Kein Update noetig - der Code wird beim Einloesen nicht veraendert (er bleibt
        // fuer jedes weitere Geraet gueltig, bis er ablaeuft oder der Trainer ihn loescht).
        allow update: if false;
        allow delete: if isTrainer();
      }

      // "players/{playerId}" wird von Spielern immer per direktem Dokument-Get
      // abgerufen (nie als Listenabfrage der ganzen Collection), deshalb reicht hier
      // der Pfad-Vergleich. "ratings" und "developmentPlans" werden von Spielern dagegen
      // per collectionGroup-Abfrage mit einem "where(playerId == ...)"-Filter gelesen -
      // Firestore kann eine Listenabfrage nur zulassen, wenn die Regel selbst auf ein
      // Datenfeld (nicht auf das Pfadsegment) prueft, das exakt zum Abfragefilter passt.
      // Deshalb tragen diese beiden Dokumenttypen zusaetzlich ein eigenes "playerId"-Feld.
      match /players/{playerId} {
        allow read: if isTrainer() || isPlayerFor(playerId);
        allow write: if isTrainer();

        match /developmentPlans/{planId} {
          // ".get('playerId', null)" statt direktem Feldzugriff - gleiche Absicherung wie
          // bei isExpired(): ein Trainer-Dokument hat kein "playerId"-Feld, direkter
          // Zugriff wuerde die Regelauswertung in diesem (eigentlich schon durch
          // isTrainer() abgedeckten) Fall unnoetig riskant machen.
          allow read: if isTrainer() || (isTeamMember() && resource.data.playerId == memberDoc().data.get('playerId', null));
          allow write: if isTrainer();
        }
      }

      match /events/{eventId} {
        allow read: if isTeamMember();
        allow write: if isTrainer();

        match /ratings/{playerId} {
          // ".get('playerId', null)" statt direktem Feldzugriff - gleiche Absicherung wie
          // bei isExpired(): ein Trainer-Dokument hat kein "playerId"-Feld, direkter
          // Zugriff wuerde die Regelauswertung in diesem (eigentlich schon durch
          // isTrainer() abgedeckten) Fall unnoetig riskant machen.
          allow read: if isTrainer() || (isTeamMember() && resource.data.playerId == memberDoc().data.get('playerId', null));
          allow write: if isTrainer();
        }
      }

      match /opponents/{opponentId} {
        allow read, write: if isTrainer();
      }

      // Altes Einzeldokument aus dem Single-Blob-Modell - nur fuer die einmalige
      // Migration in die neue Struktur, danach kann es geloescht werden.
      match /appState/current {
        allow read, write: if isTrainer();
      }
    }
  }
}
